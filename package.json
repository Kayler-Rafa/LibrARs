{
  "name": "librars-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c cyan,green \"npm run -w apps/frontend dev\" \"npm run -w apps/backend dev\"",
    "dev:frontend": "npm run -w apps/frontend dev",
    "dev:backend": "npm run -w apps/backend dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm run -w apps/frontend build",
    "build:backend": "npm run -w apps/backend build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run -w apps/frontend lint",
    "lint:backend": "npm run -w apps/backend lint",
    "lint:fix": "npm run lint:frontend -- --fix && npm run lint:backend -- --fix",
    "format": "prettier --write apps/frontend/src/ apps/backend/src/",
    "preview": "npm run -w apps/frontend preview",
    "test": "npm run -w apps/frontend test",
    "test:ui": "npm run -w apps/frontend test:ui",
    "test:coverage": "npm run -w apps/frontend test:coverage",
    "type-check": "npm run type-check:frontend && npm run type-check:backend",
    "type-check:frontend": "npm run -w apps/frontend type-check",
    "type-check:backend": "npm run -w apps/backend type-check",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod": "docker compose up --build",
    "docker:prod:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3"
  }
}
