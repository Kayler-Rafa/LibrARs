# ─────────────────────────────────────────────────────────────────────────────
#  Libras AR — variáveis de ambiente
#  Copie para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# URL do backend. Deixe em branco para usar o proxy do Vite (desenvolvimento sem Docker)
# Com Docker: http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# Supabase (legado — não é mais necessário com o backend próprio)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Backend ──────────────────────────────────────────────────────────────────
# Conexão com o PostgreSQL
DATABASE_URL=postgres://libras:libras_dev_pw@localhost:5432/libras_ar

# Chave para assinar JWTs — mude em produção!
JWT_SECRET=mude-esse-valor-em-producao

# Origens permitidas pelo CORS (separe por vírgula se precisar de mais de uma)
CORS_ORIGIN=http://localhost:5173

# Porta do backend
PORT=3001

# ── Docker Compose ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=libras_dev_pw
